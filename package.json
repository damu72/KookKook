{
  "name": "kookkook",
  "version": "0.1.0",
  "private": true,
  "description": "KookKook monorepo",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:topic": "npm run dev -w @kookkook/topic-service",
    "dev:participation": "npm run dev -w @kookkook/participation-service",
    "dev:capacity": "npm run dev -w @kookkook/capacity-service",
    "dev:trust": "npm run dev -w @kookkook/trust-service",
    "dev:frontend": "npm run dev -w @kookkook/frontend",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
